<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ruoyi.data.mapper.CleanExecuteHistoryMapper">

    <resultMap id="BaseResultMap" type="com.ruoyi.data.domain.CleanExecuteHistory">
        <id property="id" column="id"/>
        <result property="executeMode" column="execute_mode"/>
        <result property="applyDataSource" column="apply_data_source"/>
        <result property="runTime" column="run_time"/>
        <result property="configJson" column="config_json"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO clean_rule_config
            (execute_mode, apply_data_source, run_time, config_json, status,cron_expression)
        VALUES
            (#{executeMode}, #{applyDataSource}, #{runTime},
             #{configJson}, #{status}, #{cronExpression})
    </insert>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM clean_rule_config
        WHERE id = #{id}
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT * FROM clean_rule_config
        ORDER BY create_time DESC
    </select>

    <update id="updateStatus">
        UPDATE clean_rule_config
        SET status = #{status}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM clean_rule_config
        WHERE id = #{id}
    </delete>

</mapper>