<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.robots.mapper.RobotWarningsMapper">
    
    <resultMap type="RobotWarnings" id="RobotWarningsResult">
        <result property="id"    column="id"    />
        <result property="robotId"    column="robot_id"    />
        <result property="warningType"    column="warning_type"    />
        <result property="warningContent"    column="warning_content"    />
        <result property="warningLevel"    column="warning_level"    />
        <result property="status"    column="status"    />
        <result property="resolveTime"    column="resolve_time"    />
        <result property="resolveUser"    column="resolve_user"    />
        <result property="resolveNote"    column="resolve_note"    />
        <result property="createdAt"    column="created_at"    />
    </resultMap>

    <sql id="selectRobotWarningsVo">
        select id, robot_id, warning_type, warning_content, warning_level, status, resolve_time, resolve_user, resolve_note, created_at from robot_warnings
    </sql>

    <select id="selectRobotWarningsList" parameterType="RobotWarnings" resultMap="RobotWarningsResult">
        <include refid="selectRobotWarningsVo"/>
        <where>
            <if test="status != null  and status != ''"> and status = #{status}</if>
            <if test="robotId != null  and robotId != ''"> and robot_id = #{robotId}</if>
        </where>
    </select>
    
    <select id="selectRobotWarningsById" parameterType="String" resultMap="RobotWarningsResult">
        <include refid="selectRobotWarningsVo"/>
        where id = #{id}
    </select>

    <insert id="insertRobotWarnings" parameterType="RobotWarnings" useGeneratedKeys="true" keyProperty="id">
        insert into robot_warnings
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="robotId != null and robotId != ''">robot_id,</if>
            <if test="warningType != null and warningType != ''">warning_type,</if>
            <if test="warningContent != null and warningContent != ''">warning_content,</if>
            <if test="warningLevel != null and warningLevel != ''">warning_level,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="resolveTime != null">resolve_time,</if>
            <if test="resolveUser != null">resolve_user,</if>
            <if test="resolveNote != null">resolve_note,</if>
            <if test="createdAt != null">created_at,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="robotId != null and robotId != ''">#{robotId},</if>
            <if test="warningType != null and warningType != ''">#{warningType},</if>
            <if test="warningContent != null and warningContent != ''">#{warningContent},</if>
            <if test="warningLevel != null and warningLevel != ''">#{warningLevel},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="resolveTime != null">#{resolveTime},</if>
            <if test="resolveUser != null">#{resolveUser},</if>
            <if test="resolveNote != null">#{resolveNote},</if>
            <if test="createdAt != null">#{createdAt},</if>
         </trim>
    </insert>

    <update id="updateRobotWarnings" parameterType="RobotWarnings">
        update robot_warnings
        <trim prefix="SET" suffixOverrides=",">
            <if test="robotId != null and robotId != ''">robot_id = #{robotId},</if>
            <if test="warningType != null and warningType != ''">warning_type = #{warningType},</if>
            <if test="warningContent != null and warningContent != ''">warning_content = #{warningContent},</if>
            <if test="warningLevel != null and warningLevel != ''">warning_level = #{warningLevel},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="resolveTime != null">resolve_time = #{resolveTime},</if>
            <if test="resolveUser != null">resolve_user = #{resolveUser},</if>
            <if test="resolveNote != null">resolve_note = #{resolveNote},</if>
            <if test="createdAt != null">created_at = #{createdAt},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteRobotWarningsById" parameterType="String">
        delete from robot_warnings where id = #{id}
    </delete>

    <delete id="deleteRobotWarningsByIds" parameterType="String">
        delete from robot_warnings where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>