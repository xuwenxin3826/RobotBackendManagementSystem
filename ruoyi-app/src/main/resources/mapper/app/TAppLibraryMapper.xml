<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.app.mapper.TAppLibraryMapper">
    
    <resultMap type="TAppLibrary" id="TAppLibraryResult">
        <result property="id"    column="id"    />
        <result property="appId"    column="app_id"    />
        <result property="appName"    column="app_name"    />
        <result property="appType"    column="app_type"    />
        <result property="enabled"    column="enabled"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
        <result property="description"    column="description"    />
        <result property="version"    column="version"    />
    </resultMap>

    <sql id="selectTAppLibraryVo">
        select id, app_id, app_name, app_type, enabled, create_time, update_time, description, version from t_app_library
    </sql>

    <select id="selectTAppLibraryList" parameterType="TAppLibrary" resultMap="TAppLibraryResult">
        <include refid="selectTAppLibraryVo"/>
        <where>  
            <if test="appId != null  and appId != ''"> and app_id = #{appId}</if>
            <if test="appName != null  and appName != ''"> and app_name like concat('%', #{appName}, '%')</if>
            <if test="appType != null "> and app_type = #{appType}</if>
            <if test="enabled != null "> and enabled = #{enabled}</if>
        </where>
    </select>
    
    <select id="selectTAppLibraryById" parameterType="Long" resultMap="TAppLibraryResult">
        <include refid="selectTAppLibraryVo"/>
        where id = #{id}
    </select>

    <insert id="insertTAppLibrary" parameterType="TAppLibrary" useGeneratedKeys="true" keyProperty="id">
        insert into t_app_library
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="appId != null and appId != ''">app_id,</if>
            <if test="appName != null and appName != ''">app_name,</if>
            <if test="appType != null">app_type,</if>
            <if test="enabled != null">enabled,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="description != null">description,</if>
            <if test="version != null">version,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="appId != null and appId != ''">#{appId},</if>
            <if test="appName != null and appName != ''">#{appName},</if>
            <if test="appType != null">#{appType},</if>
            <if test="enabled != null">#{enabled},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="description != null">#{description},</if>
            <if test="version != null">#{version},</if>
         </trim>
    </insert>

    <update id="updateTAppLibrary" parameterType="TAppLibrary">
        update t_app_library
        <trim prefix="SET" suffixOverrides=",">
            <if test="appId != null and appId != ''">app_id = #{appId},</if>
            <if test="appName != null and appName != ''">app_name = #{appName},</if>
            <if test="appType != null">app_type = #{appType},</if>
            <if test="enabled != null">enabled = #{enabled},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="description != null">description = #{description},</if>
            <if test="version != null">version = #{version},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteTAppLibraryById" parameterType="Long">
        delete from t_app_library where id = #{id}
    </delete>

    <delete id="deleteTAppLibraryByIds" parameterType="String">
        delete from t_app_library where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>