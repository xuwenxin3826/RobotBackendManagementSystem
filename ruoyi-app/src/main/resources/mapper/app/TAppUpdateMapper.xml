<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.app.mapper.TAppUpdateMapper">
    
    <resultMap type="TAppUpdate" id="TAppUpdateResult">
        <result property="id"    column="id"    />
        <result property="appId"    column="app_id"    />
        <result property="updateVersion"    column="update_version"    />
        <result property="updateContent"    column="update_content"    />
        <result property="updateStatus"    column="update_status"    />
        <result property="robotId"    column="robot_id"    />
        <result property="updateTime"    column="update_time"    />
        <result property="failReason"    column="fail_reason"    />
        <result property="createTime"    column="create_time"    />
    </resultMap>

    <sql id="selectTAppUpdateVo">
        select id, app_id, update_version, update_content, update_status, robot_id, update_time, fail_reason, create_time from t_app_update
    </sql>

    <select id="selectTAppUpdateList" parameterType="TAppUpdate" resultMap="TAppUpdateResult">
        <include refid="selectTAppUpdateVo"/>
        <where>  
            <if test="appId != null  and appId != ''"> and app_id = #{appId}</if>
            <if test="updateVersion != null  and updateVersion != ''"> and update_version = #{updateVersion}</if>
            <if test="updateContent != null  and updateContent != ''"> and update_content = #{updateContent}</if>
            <if test="updateStatus != null "> and update_status = #{updateStatus}</if>
            <if test="robotId != null  and robotId != ''"> and robot_id = #{robotId}</if>
            <if test="failReason != null  and failReason != ''"> and fail_reason = #{failReason}</if>
        </where>
    </select>
    
    <select id="selectTAppUpdateById" parameterType="Long" resultMap="TAppUpdateResult">
        <include refid="selectTAppUpdateVo"/>
        where id = #{id}
    </select>

    <insert id="insertTAppUpdate" parameterType="TAppUpdate" useGeneratedKeys="true" keyProperty="id">
        insert into t_app_update
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="appId != null and appId != ''">app_id,</if>
            <if test="updateVersion != null and updateVersion != ''">update_version,</if>
            <if test="updateContent != null and updateContent != ''">update_content,</if>
            <if test="updateStatus != null">update_status,</if>
            <if test="robotId != null">robot_id,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="failReason != null">fail_reason,</if>
            <if test="createTime != null">create_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="appId != null and appId != ''">#{appId},</if>
            <if test="updateVersion != null and updateVersion != ''">#{updateVersion},</if>
            <if test="updateContent != null and updateContent != ''">#{updateContent},</if>
            <if test="updateStatus != null">#{updateStatus},</if>
            <if test="robotId != null">#{robotId},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="failReason != null">#{failReason},</if>
            <if test="createTime != null">#{createTime},</if>
         </trim>
    </insert>

    <update id="updateTAppUpdate" parameterType="TAppUpdate">
        update t_app_update
        <trim prefix="SET" suffixOverrides=",">
            <if test="appId != null and appId != ''">app_id = #{appId},</if>
            <if test="updateVersion != null and updateVersion != ''">update_version = #{updateVersion},</if>
            <if test="updateContent != null and updateContent != ''">update_content = #{updateContent},</if>
            <if test="updateStatus != null">update_status = #{updateStatus},</if>
            <if test="robotId != null">robot_id = #{robotId},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="failReason != null">fail_reason = #{failReason},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteTAppUpdateById" parameterType="Long">
        delete from t_app_update where id = #{id}
    </delete>

    <delete id="deleteTAppUpdateByIds" parameterType="String">
        delete from t_app_update where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>