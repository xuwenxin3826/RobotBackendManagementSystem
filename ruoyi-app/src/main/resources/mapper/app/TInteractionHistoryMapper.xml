<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.app.mapper.TInteractionHistoryMapper">
    
    <resultMap type="TInteractionHistory" id="TInteractionHistoryResult">
        <result property="id"    column="id"    />
        <result property="taskId"    column="task_id"    />
        <result property="interactionId"    column="interaction_id"    />
        <result property="robotId"    column="robot_id"    />
        <result property="userId"    column="user_id"    />
        <result property="userName"    column="user_name"    />
        <result property="interactionType"    column="interaction_type"    />
        <result property="interactionContent"    column="interaction_content"    />
        <result property="interactionTime"    column="interaction_time"    />
        <result property="duration"    column="duration"    />
        <result property="rating"    column="rating"    />
        <result property="evaluationText"    column="evaluation_text"    />
        <result property="status"    column="status"    />
        <result property="extInfo"    column="ext_info"    />
    </resultMap>

    <sql id="selectTInteractionHistoryVo">
        select id, task_id, interaction_id, robot_id, user_id, user_name, interaction_type, interaction_content, interaction_time, duration, rating, evaluation_text, status, ext_info from t_interaction_history
    </sql>

    <select id="selectTInteractionHistoryList" parameterType="TInteractionHistory" resultMap="TInteractionHistoryResult">
        <include refid="selectTInteractionHistoryVo"/>
        <where>  
            <if test="taskId != null  and taskId != ''"> and task_id like CONCAT('%', #{taskId}, '%')</if>
            <if test="interactionId != null  and interactionId != ''"> and interaction_id like CONCAT('%', #{interactionId}, '%')</if>
            <if test="robotId != null  and robotId != ''"> and robot_id like CONCAT('%', #{robotId}, '%')</if>
            <if test="userId != null  and userId != ''"> and user_id like CONCAT('%', #{userId}, '%')</if>
        </where>
    </select>
    
    <select id="selectTInteractionHistoryById" parameterType="Long" resultMap="TInteractionHistoryResult">
        <include refid="selectTInteractionHistoryVo"/>
        where id = #{id}
    </select>

    <insert id="insertTInteractionHistory" parameterType="TInteractionHistory" useGeneratedKeys="true" keyProperty="id">
        insert into t_interaction_history
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="taskId != null and taskId != ''">task_id,</if>
            <if test="interactionId != null and interactionId != ''">interaction_id,</if>
            <if test="robotId != null and robotId != ''">robot_id,</if>
            <if test="userId != null">user_id,</if>
            <if test="userName != null">user_name,</if>
            <if test="interactionType != null">interaction_type,</if>
            <if test="interactionContent != null">interaction_content,</if>
            <if test="interactionTime != null">interaction_time,</if>
            <if test="duration != null">duration,</if>
            <if test="rating != null">rating,</if>
            <if test="evaluationText != null">evaluation_text,</if>
            <if test="status != null">status,</if>
            <if test="extInfo != null">ext_info,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="taskId != null and taskId != ''">#{taskId},</if>
            <if test="interactionId != null and interactionId != ''">#{interactionId},</if>
            <if test="robotId != null and robotId != ''">#{robotId},</if>
            <if test="userId != null">#{userId},</if>
            <if test="userName != null">#{userName},</if>
            <if test="interactionType != null">#{interactionType},</if>
            <if test="interactionContent != null">#{interactionContent},</if>
            <if test="interactionTime != null">#{interactionTime},</if>
            <if test="duration != null">#{duration},</if>
            <if test="rating != null">#{rating},</if>
            <if test="evaluationText != null">#{evaluationText},</if>
            <if test="status != null">#{status},</if>
            <if test="extInfo != null">#{extInfo},</if>
         </trim>
    </insert>

    <update id="updateTInteractionHistory" parameterType="TInteractionHistory">
        update t_interaction_history
        <trim prefix="SET" suffixOverrides=",">
            <if test="taskId != null and taskId != ''">task_id = #{taskId},</if>
            <if test="interactionId != null and interactionId != ''">interaction_id = #{interactionId},</if>
            <if test="robotId != null and robotId != ''">robot_id = #{robotId},</if>
            <if test="userId != null">user_id = #{userId},</if>
            <if test="userName != null">user_name = #{userName},</if>
            <if test="interactionType != null">interaction_type = #{interactionType},</if>
            <if test="interactionContent != null">interaction_content = #{interactionContent},</if>
            <if test="interactionTime != null">interaction_time = #{interactionTime},</if>
            <if test="duration != null">duration = #{duration},</if>
            <if test="rating != null">rating = #{rating},</if>
            <if test="evaluationText != null">evaluation_text = #{evaluationText},</if>
            <if test="status != null">status = #{status},</if>
            <if test="extInfo != null">ext_info = #{extInfo},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteTInteractionHistoryById" parameterType="Long">
        delete from t_interaction_history where id = #{id}
    </delete>

    <delete id="deleteTInteractionHistoryByIds" parameterType="String">
        delete from t_interaction_history where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>